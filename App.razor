@implements IDisposable
@inject Prism.SourceGenerators.Docs.Services.LocalizationService Loc

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" @key="Loc.Culture" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
</Router>

@code {
    protected override void OnInitialized() => Loc.CultureChanged += OnCultureChanged;

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Loc.CultureChanged -= OnCultureChanged;
}
