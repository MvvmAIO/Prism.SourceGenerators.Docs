@page "/getting-started"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("gettingStarted.pageTitle")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">@Loc.T("gettingStarted.title")</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@Loc.T("gettingStarted.lead")</MudText>

<MudStack Spacing="4">
    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPackageTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPackageBody")</MudText>
        <pre class="docs-code mud-width-full"><code>dotnet add package MvvmAIO.Prism.SourceGenerators</code></pre>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPartialTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPartialBody")</MudText>
        <pre class="docs-code mud-width-full"><code>public partial class MainViewModel : BindableBase
{
    [ObservableProperty]
    private string _title = "";
}</code></pre>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPrismTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPrismBody")</MudText>
        <pre class="docs-code mud-width-full"><code>dotnet add package MvvmAIO.Prism.Bcl.Commands</code></pre>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="0" Outlined="true">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepSamplesTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepSamplesBody")</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" Target="_blank" rel="noopener noreferrer">Prism.SourceGenerators.Samples</MudButton>
    </MudPaper>
</MudStack>
