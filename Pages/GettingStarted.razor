@page "/getting-started"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("gettingStarted.pageTitle")</PageTitle>

<h1 class="mb-3">@Loc.T("gettingStarted.title")</h1>
<p class="lead text-muted">@Loc.T("gettingStarted.lead")</p>

<div class="docs-steps mt-4">
    <div class="docs-step mb-4 pb-4 border-bottom">
        <h2 class="h5">@Loc.T("gettingStarted.stepPackageTitle")</h2>
        <p>@Loc.T("gettingStarted.stepPackageBody")</p>
        <pre class="docs-code rounded p-3 mb-0"><code>dotnet add package MvvmAIO.Prism.SourceGenerators</code></pre>
    </div>
    <div class="docs-step mb-4 pb-4 border-bottom">
        <h2 class="h5">@Loc.T("gettingStarted.stepPartialTitle")</h2>
        <p>@Loc.T("gettingStarted.stepPartialBody")</p>
        <pre class="docs-code rounded p-3 mb-0"><code>public partial class MainViewModel : BindableBase
{
    [ObservableProperty]
    private string _title = "";
}</code></pre>
    </div>
    <div class="docs-step mb-4 pb-4 border-bottom">
        <h2 class="h5">@Loc.T("gettingStarted.stepPrismTitle")</h2>
        <p>@Loc.T("gettingStarted.stepPrismBody")</p>
        <pre class="docs-code rounded p-3 mb-0"><code>dotnet add package MvvmAIO.Prism.Bcl.Commands</code></pre>
    </div>
    <div class="docs-step">
        <h2 class="h5">@Loc.T("gettingStarted.stepSamplesTitle")</h2>
        <p class="mb-2">@Loc.T("gettingStarted.stepSamplesBody")</p>
        <a class="btn btn-outline-secondary" href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" target="_blank" rel="noopener noreferrer">Prism.SourceGenerators.Samples</a>
    </div>
</div>
