@page "/getting-started"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("gettingStarted.pageTitle")</PageTitle>

<MudText Typo="Typo.h4" Class="docs-section-title mb-2">@Loc.T("gettingStarted.title")</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@Loc.T("gettingStarted.lead")</MudText>

<MudStack Spacing="4">
    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPackageTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPackageBody")</MudText>
        <pre class="docs-code mud-width-full"><code>dotnet add package MvvmAIO.Prism.SourceGenerators</code></pre>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPartialTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPartialBody")</MudText>
        <pre class="docs-code mud-width-full"><code>public partial class MainViewModel : BindableBase
{
    [ObservableProperty]
    private string _title = "";
}</code></pre>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepPrismTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepPrismBody")</MudText>
        <pre class="docs-code mud-width-full"><code>dotnet add package MvvmAIO.Prism.Bcl.Commands</code></pre>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("gettingStarted.stepSamplesTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">@Loc.T("gettingStarted.stepSamplesBody")</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" Target="_blank" rel="noopener noreferrer">Prism.SourceGenerators.Samples</MudButton>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("gettingStarted.requirementsTitle")</MudText>
        <ul>
            <li>@Loc.T("gettingStarted.reqDotnetSdk")</li>
            <li>@Loc.T("gettingStarted.reqIde")</li>
            <li>@Loc.T("gettingStarted.reqPrismBase")</li>
        </ul>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("gettingStarted.recommendedPackagesTitle")</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">
            @Loc.T("gettingStarted.recommendedPackagesBody")
        </MudText>
        <pre class="docs-code mud-width-full"><code>&lt;ItemGroup&gt;
  &lt;PackageReference Include="MvvmAIO.Prism.SourceGenerators" Version="0.2.0" /&gt;
  &lt;!-- Prism 8.1.97 async command support --&gt;
  &lt;PackageReference Include="MvvmAIO.Prism.Bcl.Commands" Version="0.2.0" /&gt;
&lt;/ItemGroup&gt;</code></pre>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("gettingStarted.buildValidateTitle")</MudText>
        <MudStack Spacing="2">
            <MudText Typo="Typo.body2">@Loc.T("gettingStarted.buildSolutionLabel")</MudText>
            <pre class="docs-code mud-width-full"><code>dotnet build Prism.SourceGenerators.slnx</code></pre>
            <MudText Typo="Typo.body2">@Loc.T("gettingStarted.buildNukeLabel")</MudText>
            <pre class="docs-code mud-width-full"><code>dotnet run --project build/_build.csproj -- --target Ci --configuration Release</code></pre>
        </MudStack>
    </MudPaper>

    <MudPaper Class="docs-step-card pa-5" Elevation="0">
        <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("gettingStarted.upgradeNotesTitle")</MudText>
        <ul>
            <li>@Loc.T("gettingStarted.upgradeCsharp13")</li>
            <li>@Loc.T("gettingStarted.upgradeCsharp14")</li>
            <li>@Loc.T("gettingStarted.upgradeValueTask")</li>
            <li>@Loc.T("gettingStarted.upgradePsg3002")</li>
        </ul>
    </MudPaper>
</MudStack>
