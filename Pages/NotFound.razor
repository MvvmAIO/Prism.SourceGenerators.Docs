@page "/not-found"
@layout MainLayout
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("notFound.title")</PageTitle>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">@Loc.T("notFound.title")</MudText>
    <MudText Typo="Typo.body2">@Loc.T("notFound.body")</MudText>
</MudAlert>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Href="">@Loc.T("nav.home")</MudButton>
