@page "/reference"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("reference.pageTitle")</PageTitle>

<h1 class="mb-3">@Loc.T("reference.title")</h1>
<p class="lead text-muted">@Loc.T("reference.lead")</p>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <div class="docs-panel p-4 rounded-3 border h-100 d-flex flex-column">
            <h2 class="h5 mb-3">@Loc.T("reference.cardWikiTitle")</h2>
            <p class="flex-grow-1">@Loc.T("reference.cardWikiBody")</p>
            <a class="btn btn-primary" href="https://deepwiki.com/MvvmAIO/Prism.SourceGenerators" target="_blank" rel="noopener noreferrer">DeepWiki</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="docs-panel p-4 rounded-3 border h-100 d-flex flex-column">
            <h2 class="h5 mb-3">@Loc.T("reference.cardGitHubTitle")</h2>
            <p class="flex-grow-1">@Loc.T("reference.cardGitHubBody")</p>
            <a class="btn btn-outline-primary" href="https://github.com/MvvmAIO/Prism.SourceGenerators" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="docs-panel p-4 rounded-3 border h-100 d-flex flex-column">
            <h2 class="h5 mb-3">@Loc.T("reference.cardSamplesTitle")</h2>
            <p class="flex-grow-1">@Loc.T("reference.cardSamplesBody")</p>
            <a class="btn btn-outline-secondary" href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" target="_blank" rel="noopener noreferrer">Samples</a>
        </div>
    </div>
</div>
