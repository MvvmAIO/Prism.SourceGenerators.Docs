@page "/reference"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("reference.pageTitle")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">@Loc.T("reference.title")</MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="mb-6">@Loc.T("reference.lead")</MudText>

<MudGrid Spacing="4">
    <MudItem xs="12" md="4">
        <MudCard Class="h-100" Elevation="0" Outlined="true">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("reference.cardWikiTitle")</MudText>
                <MudText Typo="Typo.body2" Class="mb-4">@Loc.T("reference.cardWikiBody")</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="https://deepwiki.com/MvvmAIO/Prism.SourceGenerators" Target="_blank" rel="noopener noreferrer">DeepWiki</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudCard Class="h-100" Elevation="0" Outlined="true">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("reference.cardGitHubTitle")</MudText>
                <MudText Typo="Typo.body2" Class="mb-4">@Loc.T("reference.cardGitHubBody")</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Href="https://github.com/MvvmAIO/Prism.SourceGenerators" Target="_blank" rel="noopener noreferrer">GitHub</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudCard Class="h-100" Elevation="0" Outlined="true">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-3">@Loc.T("reference.cardSamplesTitle")</MudText>
                <MudText Typo="Typo.body2" Class="mb-4">@Loc.T("reference.cardSamplesBody")</MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true" Href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" Target="_blank" rel="noopener noreferrer">Samples</MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>
