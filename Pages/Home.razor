@page "/"
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<PageTitle>@Loc.T("home.pageTitle")</PageTitle>

<section class="docs-hero rounded-3 p-4 p-md-5 mb-4 text-white">
    <h1 class="display-6 fw-bold">@Loc.T("home.heroTitle")</h1>
    <p class="lead mb-0 col-lg-10">@Loc.T("home.heroLead")</p>
</section>

<h2 class="h4 mb-3">@Loc.T("home.sectionWhat")</h2>
<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="docs-card h-100 p-3 rounded-3 border bg-body-secondary bg-opacity-25">
            <h3 class="h6 text-uppercase text-muted">Observable</h3>
            <p class="mb-0 small">@Loc.T("home.whatObservable")</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="docs-card h-100 p-3 rounded-3 border bg-body-secondary bg-opacity-25">
            <h3 class="h6 text-uppercase text-muted">Commands</h3>
            <p class="mb-0 small">@Loc.T("home.whatCommands")</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="docs-card h-100 p-3 rounded-3 border bg-body-secondary bg-opacity-25">
            <h3 class="h6 text-uppercase text-muted">Registration</h3>
            <p class="mb-0 small">@Loc.T("home.whatRegistration")</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="docs-card h-100 p-3 rounded-3 border bg-body-secondary bg-opacity-25">
            <h3 class="h6 text-uppercase text-muted">Diagnostics</h3>
            <p class="mb-0 small">@Loc.T("home.whatDiagnostics")</p>
        </div>
    </div>
</div>

<h2 class="h4 mb-3">@Loc.T("home.sectionLayout")</h2>
<ul class="docs-list mb-4">
    <li>@Loc.T("home.layoutShared")</li>
    <li>@Loc.T("home.layoutCore")</li>
    <li>@Loc.T("home.layoutRoslyn")</li>
    <li>@Loc.T("home.layoutBcl")</li>
    <li>@Loc.T("home.layoutSamples")</li>
</ul>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="docs-panel p-4 rounded-3 border h-100">
            <h2 class="h5 mb-3">@Loc.T("home.sectionMore")</h2>
            <p class="mb-3">@Loc.T("home.moreDeepWiki")</p>
            <p class="mb-0 text-muted small">@Loc.T("home.moreReadme")</p>
            <a class="btn btn-primary mt-3" href="https://deepwiki.com/MvvmAIO/Prism.SourceGenerators" target="_blank" rel="noopener noreferrer">DeepWiki</a>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="docs-panel p-4 rounded-3 border h-100">
            <h2 class="h5 mb-3">@Loc.T("common.openGitHub")</h2>
            <p class="mb-3">README, CONTRIBUTING, CI workflows, and issue tracker.</p>
            <a class="btn btn-outline-primary" href="https://github.com/MvvmAIO/Prism.SourceGenerators" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
    </div>
</div>
