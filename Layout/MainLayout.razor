@inherits LayoutComponentBase
@implements IDisposable
@using Prism.SourceGenerators.Docs.Services
@using Prism.SourceGenerators.Docs.Components
@inject LocalizationService Loc
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IBrowserViewportService Viewport

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" Color="Color.Surface" Class="docs-appbar-border">
        <MudIconButton Icon="@DrawerToggleIcon"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer"
                       aria-label="@Loc.T("common.toggleSidebar")"
                       aria-expanded="@(_drawerOpen ? "true" : "false")" />
        <MudText Typo="Typo.h6" Class="ml-2">@Loc.T("common.siteTitle")</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Fixed="true"
               ClipMode="DrawerClipMode.Always"
               Breakpoint="Breakpoint.Md"
               Elevation="2"
               Variant="@DrawerVariant.Mini"
               OpenMiniOnHover="true"
               Width="280px"
               MiniWidth="72px"
               Class="docs-mud-drawer">
        <MudDrawerHeader Dense="true" Class="docs-drawer-header">
            <MudStack Spacing="0" Class="docs-drawer-header-text">
                <MudText Typo="Typo.subtitle1" Class="docs-drawer-brand">@Loc.T("common.siteTitle")</MudText>
                <MudText Typo="Typo.caption" Class="mud-opacity-75 docs-drawer-subtitle">@Loc.T("common.siteSubtitle")</MudText>
            </MudStack>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="docs-main">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-4 pb-8">
            <MudPaper Elevation="0" Class="pa-3 mb-4 rounded-lg docs-toolbar-paper">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        <MudLink Typo="Typo.body2" Href="https://deepwiki.com/MvvmAIO/Prism.SourceGenerators" Target="_blank" rel="noopener noreferrer" Color="Color.Primary">@Loc.T("common.openDeepWiki")</MudLink>
                        <MudLink Typo="Typo.body2" Href="https://github.com/MvvmAIO/Prism.SourceGenerators" Target="_blank" rel="noopener noreferrer" Color="Color.Primary">@Loc.T("common.openGitHub")</MudLink>
                        <MudLink Typo="Typo.body2" Href="https://github.com/MvvmAIO/Prism.SourceGenerators.Samples" Target="_blank" rel="noopener noreferrer" Color="Color.Primary">@Loc.T("common.openSamples")</MudLink>
                        <MudLink Typo="Typo.body2" Href="https://www.nuget.org/packages/MvvmAIO.Prism.SourceGenerators" Target="_blank" rel="noopener noreferrer" Color="Color.Primary">@Loc.T("common.openNuGet")</MudLink>
                    </MudStack>
                    <LanguageSwitcher />
                </MudStack>
            </MudPaper>

            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _cultureBootstrapped;
    private bool _drawerOpen = true;

    private string DrawerToggleIcon =>
        _drawerOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu;

    protected override void OnInitialized()
    {
        Loc.CultureChanged += OnCultureChanged;
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await Loc.SetCultureAsync("en").ConfigureAwait(false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _cultureBootstrapped)
            return;
        _cultureBootstrapped = true;
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "docsLocale").ConfigureAwait(false);
            var browser = await JS.InvokeAsync<string?>("eval", "(function(){return navigator.language||'';})()").ConfigureAwait(false);
            await Loc.ApplyBrowserAndStorageAsync(stored, browser).ConfigureAwait(false);
        }
        catch
        {
            await Loc.SetCultureAsync("en").ConfigureAwait(false);
        }

        StateHasChanged();
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) => _ = CloseDrawerIfNarrowAsync();

    private async Task CloseDrawerIfNarrowAsync()
    {
        try
        {
            if (await Viewport.IsBreakpointWithinWindowSizeAsync(Breakpoint.SmAndDown).ConfigureAwait(false))
            {
                _drawerOpen = false;
                await InvokeAsync(StateHasChanged).ConfigureAwait(false);
            }
        }
        catch
        {
            // Viewport not ready (SSR/tests) — ignore
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    public void Dispose()
    {
        Loc.CultureChanged -= OnCultureChanged;
        Nav.LocationChanged -= OnLocationChanged;
    }
}
