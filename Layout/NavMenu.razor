@implements IDisposable
@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<MudNavMenu Rounded="true" Margin="Margin.Dense" Class="pa-2">
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home" title="@Loc.T("nav.home")">@Loc.T("nav.home")</MudNavLink>
    <MudNavLink Href="getting-started" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RocketLaunch" title="@Loc.T("nav.gettingStarted")">@Loc.T("nav.gettingStarted")</MudNavLink>
    <MudNavLink Href="generators" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AutoAwesome" title="@Loc.T("nav.generators")">@Loc.T("nav.generators")</MudNavLink>
    <MudNavLink Href="reference" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.MenuBook" title="@Loc.T("nav.reference")">@Loc.T("nav.reference")</MudNavLink>
</MudNavMenu>

@code {
    protected override void OnInitialized() => Loc.CultureChanged += OnCultureChanged;

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Loc.CultureChanged -= OnCultureChanged;
}
