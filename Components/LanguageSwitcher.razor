@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc
@inject IJSRuntime JS

<MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" OverrideStyles="false" aria-label="@Loc.T("common.language")">
    <MudButton Variant="@VariantFor("en")" OnClick="@(() => ApplyAsync("en"))">EN</MudButton>
    <MudButton Variant="@VariantFor("zh-CN")" OnClick="@(() => ApplyAsync("zh-CN"))">中文</MudButton>
    <MudButton Variant="@VariantFor("ja")" OnClick="@(() => ApplyAsync("ja"))">日本語</MudButton>
</MudButtonGroup>

@code {
    private Variant VariantFor(string culture) =>
        string.Equals(Loc.Culture, culture, StringComparison.OrdinalIgnoreCase)
            ? Variant.Filled
            : Variant.Text;

    private async Task ApplyAsync(string culture)
    {
        await Loc.SetCultureAsync(culture);
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "docsLocale", culture);
        }
        catch
        {
            // ignore storage failures (private mode, etc.)
        }
    }
}
