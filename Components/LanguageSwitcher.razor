@using Prism.SourceGenerators.Docs.Services
@inject LocalizationService Loc

<label class="docs-top-control" title="@Loc.T("common.language")">
    <span class="material-icons" aria-hidden="true">translate</span>
    <select class="docs-native-select"
            value="@Loc.Culture"
            @onchange="OnCultureChangedAsync"
            aria-label="@Loc.T("common.language")">
        <option value="en">@Loc.T("common.langEnglish")</option>
        <option value="zh-CN">@Loc.T("common.langChinese")</option>
        <option value="ja">@Loc.T("common.langJapanese")</option>
    </select>
</label>

@code {
    private async Task OnCultureChangedAsync(ChangeEventArgs e)
    {
        if (e.Value is string culture)
            await Loc.SetCultureAsync(culture);
    }
}
